# ── Paddle ─────────────────────────────────────────────────────
# Paddle Dashboard → Developer Tools → Authentication → Generate API Key
PADDLE_API_KEY=your_paddle_api_key_here

# Paddle Dashboard → Developer Tools → Notifications → your webhook → Secret key
PADDLE_WEBHOOK_SECRET=your_webhook_secret_here

# "sandbox" for testing, "production" for real payments
PADDLE_ENV=sandbox

# ── Paddle Price IDs ────────────────────────────────────────────
# Paddle Dashboard → Catalog → Products → click product → Prices tab → copy ID (starts with pri_)
PRICE_ID_100=pri_your_100_credits_price_id
PRICE_ID_500=pri_your_500_credits_price_id
PRICE_ID_1000=pri_your_1000_credits_price_id

# ── URLs ────────────────────────────────────────────────────────
SITE_ORIGIN=https://mapsleadscraper.com
PORT=3000
