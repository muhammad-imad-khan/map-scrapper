# ── Paddle ────────────────────────────────────────────────────
# Get from: paddle.com → Developer → Authentication
PADDLE_API_KEY=your_paddle_api_key_here

# Get from: paddle.com → Developer → Webhooks → your webhook → Secret Key
PADDLE_WEBHOOK_SECRET=your_webhook_secret_here

# sandbox = test mode, production = live
PADDLE_ENV=sandbox

# ── URLs ──────────────────────────────────────────────────────
SUCCESS_URL=https://mapsleadscraper.com/success
SITE_ORIGIN=https://mapsleadscraper.com

# ── Server ────────────────────────────────────────────────────
PORT=3000
